# =====================================================================
# Blocks tracking local data layers to preserve testing isolation
*.db
*.db-journal
*.sqlite
*.mosaic

# =====================================================================
# 4. SYSTEM LOGGER TEXT TRANSACTIONS
# =====================================================================
# Excludes the continuous scoreboards from your public repository
*.log
workspace_snapshots/

